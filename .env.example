# Database Configuration
DATABASE_URL=postgresql://user:password@host:5432/database

# Session Secret (Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=your-secure-random-secret-key-here

# Environment
NODE_ENV=development

# External APIs (Optional - use your own keys here)
# Get your key at: https://newsdata.io/
NEWSDATA_API_KEY=your_newsdata_api_key

# TheSportsDB API (Free tier key: 3)
THESPORTSDB_API_KEY=3

# Get your key at: https://developers.sympla.com.br/
SYMPLA_API_KEY=your_sympla_api_key

# Get your key at: https://www.eventbrite.com/platform/api
EVENTBRITE_API_KEY=your_eventbrite_api_key
